{
  "expo": {
    "name": "Tagebuch",
    "slug": "tagebuch",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "tagebuch",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1B2D"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1B2D"
      },
      "package": "com.tagebuch.app",
      "versionCode": 2
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-sharing",
      "@react-native-community/datetimepicker",
      "expo-background-fetch",
      "expo-task-manager",
      [
        "expo-secure-store",
        {
          "faceIDPermission": false
        }
      ],
      "expo-local-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Wird für Geotagging von Einträgen verwendet."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bac5672a-3f9a-4f24-9af4-c585530c0fde"
      }
    },
    "owner": "der_olaf"
  }
}
