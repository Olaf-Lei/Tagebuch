{
  "expo": {
    "name": "Tagebuch",
    "slug": "tagebuch",
    "version": "2.8.27",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "tagebuch",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1B2D"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1B2D"
      },
      "package": "com.simpletagebuch.app",
      "versionCode": 96,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "privacyPolicyUrl": "https://gist.github.com/Olaf-Lei/ab539abc2d8d4db4305b9ee2de4af95d",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.simpletagebuch.app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.googleusercontent.apps.273046032809-u3va4nkl6pe5ja7v370d0be6v8njsr9r"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-sharing",
      "@react-native-community/datetimepicker",
      "expo-background-fetch",
      "expo-task-manager",
      [
        "expo-secure-store",
        {
          "faceIDPermission": false
        }
      ],
      "expo-local-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Wird für Geotagging von Einträgen verwendet."
        }
      ],
      "expo-localization",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0F1B2D"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bac5672a-3f9a-4f24-9af4-c585530c0fde"
      }
    },
    "owner": "der_olaf"
  }
}
